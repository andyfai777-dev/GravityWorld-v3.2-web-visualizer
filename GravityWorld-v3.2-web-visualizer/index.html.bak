    </div>
  `;
  const ec1 = echarts.init(document.getElementById('chart-faction-pull'));
  ec1.setOption({ tooltip: { trigger: 'axis' }, legend: { bottom: 0, textStyle: { color: '#94a3b8', fontSize: 10 } }, grid: { left: 50, right: 20, top: 30, bottom: 50 }, xAxis: { type: 'category', data: getCharNames(), axisLabel: { color: '#64748b', rotate: 30 }, splitLine: { lineStyle: { color: '#1a2744' } } }, yAxis: { type: 'value', axisLabel: { color: '#64748b' }, splitLine: { lineStyle: { color: '#1a2744' } } }, series: buildFactionPullData(currentStep) });
  const ec2 = echarts.init(document.getElementById('chart-faction-rise'));
  const riseData = buildFactionRiseData(currentStep); const steps = appData.history.map(h => h.step);
  ec2.setOption({ tooltip: { trigger: 'axis' }, legend: { bottom: 0, textStyle: { color: '#94a3b8', fontSize: 10 } }, grid: { left: 50, right: 20, top: 30, bottom: 50 }, xAxis: { type: 'category', data: steps, axisLabel: { color: '#64748b' }, splitLine: { lineStyle: { color: '#1a2744' } } }, yAxis: { type: 'value', axisLabel: { color: '#64748b' }, splitLine: { lineStyle: { color: '#1a2744' } } }, series: riseData });
}

function renderEventsTab() {
  if (!appData || !appData.history || !appData.history.length) {
    document.getElementById('tab-events').innerHTML = '<div class="empty-state"><h2>未运行推演</h2><p>请先加载配置并点击「运行推演」</p></div>';
    return;
  }
  const container = document.getElementById('tab-events');
  container.innerHTML = `
    <div class="grid-2">
      <div class="card"><div class="panel-title">叛变 + 锚点时间线</div><div id="chart-timeline" class="chart"></div></div>
      <div class="card"><div class="panel-title">动态锚点检测</div><div id="anchor-table" style="overflow:auto;max-height:460px;"></div></div>
    </div>
  `;
  const tl = buildTimelineData(currentStep); const ec = echarts.init(document.getElementById('chart-timeline'));
  ec.setOption({ tooltip: { formatter: p => { const d = p.data; return '<strong>' + d.name + '</strong><br/>步数: ' + d.value[0]; }, backgroundColor: '#111827', borderColor: '#2a3a5c', textStyle: { color: '#e2e8f0' } }, grid: { left: 200, right: 30, top: 30, bottom: 40 }, xAxis: { type: 'value', min: 0, max: appData.history.length - 1, axisLabel: { color: '#64748b' }, splitLine: { lineStyle: { color: '#1a2744' } }, markLine: { silent: true, data: [{ xAxis: currentStep, lineStyle: { color: '#f59e0b', type: 'dashed' }, label: { formatter: 'Step ' + currentStep, color: '#f59e0b' } }] } }, yAxis: { type: 'category', data: tl.yCats, axisLabel: { color: '#64748b', fontSize: 10 }, splitLine: { lineStyle: { color: '#1a2744' } } }, series: [{ type: 'scatter', data: tl.data, label: { show: false } }] });
  renderAnchorTable();
}

function renderAnchorTable() {
  const container = document.getElementById('anchor-table');
  const rows = appData.anchor_log.slice(-30).reverse().map(a => {
    let tagClass = 'tag-anchor'; if (a.type === 'defection') tagClass = 'tag-defection'; else if (a.anchor_type === 'relation') tagClass = 'tag-dynamic'; else if (a.anchor_type === 'individual') tagClass = 'tag-dynamic';
    return `<tr><td>${a.step}</td><td><span class="tag ${tagClass}">${a.anchor_type}</span></td><td>${a.name}</td><td>${a.description}</td></tr>`;
  }).join('');
  container.innerHTML = `<table class="data-table"><thead><tr><th>步数</th><th>类型</th><th>名称</th><th>描述</th></tr></thead><tbody>${rows || '<tr><td colspan="4" style="text-align:center;color:#64748b;">无锚点事件</td></tr>'}</tbody></table>`;
}

function renderPhysicsTab() {
  if (!appData || !appData.history || !appData.history.length) {
    document.getElementById('tab-physics').innerHTML = '<div class="empty-state"><h2>未运行推演</h2><p>请先加载配置并点击「运行推演」</p></div>';
    return;
  }
  const container = document.getElementById('tab-physics');
  container.innerHTML = `
    <div class="grid-2">
      <div class="card"><div class="panel-title">高斯力曲线（物理引擎可视化）</div><div id="chart-gauss" class="chart"></div></div>
      <div class="card"><div class="panel-title">艺术节奏曲线（当前步高亮）</div><div id="chart-art" class="chart"></div></div>
    </div>
  `;
  const R = appData.meta.distance_scale; const peak = appData.meta.peak_force; const x = [];
  for (let i = 0; i <= 100; i++) { const r = (i / 100) * 3 * R; const r_norm = r / R; const gauss = r_norm * Math.exp(-r_norm * r_norm); const F = appData.meta.G * 0.5 * 0.5 * 1.0 * peak * gauss; x.push([r.toFixed(2), F.toFixed(3)]); }
  const ec1 = echarts.init(document.getElementById('chart-gauss'));
  ec1.setOption({ tooltip: { trigger: 'axis', backgroundColor: '#111827', borderColor: '#2a3a5c', textStyle: { color: '#e2e8f0' } }, grid: { left: 50, right: 30, top: 30, bottom: 50 }, xAxis: { type: 'value', name: '距离 r', nameTextStyle: { color: '#64748b' }, axisLabel: { color: '#64748b' }, splitLine: { lineStyle: { color: '#1a2744' } } }, yAxis: { type: 'value', name: '引力 F', nameTextStyle: { color: '#64748b' }, axisLabel: { color: '#64748b' }, splitLine: { lineStyle: { color: '#1a2744' } } }, series: [{ type: 'line', smooth: true, data: x, lineStyle: { color: '#f59e0b', width: 2.5 }, areaStyle: { color: 'rgba(245,158,11,0.15)' }, markLine: { silent: true, data: [{ xAxis: R.toFixed(2), lineStyle: { color: '#f59e0b', type: 'dashed' }, label: { formatter: 'R = ' + R, color: '#f59e0b' } }] } }] });
  const art = buildArtData(currentStep); const ec2 = echarts.init(document.getElementById('chart-art'));
  ec2.setOption({ tooltip: { trigger: 'axis', backgroundColor: '#111827', borderColor: '#2a3a5c', textStyle: { color: '#e2e8f0' } }, legend: { bottom: 0, textStyle: { color: '#94a3b8', fontSize: 10 } }, grid: { left: 50, right: 30, top: 30, bottom: 50 }, xAxis: { type: 'category', data: art.steps, axisLabel: { color: '#64748b' }, splitLine: { lineStyle: { color: '#1a2744' } }, markLine: { silent: true, data: [{ xAxis: currentStep, lineStyle: { color: '#f59e0b', type: 'dashed' }, label: { formatter: 'Step ' + currentStep, color: '#f59e0b' } }] } }, yAxis: { type: 'value', min: 0, max: 1, axisLabel: { color: '#64748b' }, splitLine: { lineStyle: { color: '#1a2744' } } }, series: [{ name: 'dramatic', type: 'line', data: art.dramatic, smooth: true, lineStyle: { color: '#ef4444' }, showSymbol: false }, { name: 'surprise', type: 'line', data: art.surprise, smooth: true, lineStyle: { color: '#a78bfa' }, showSymbol: false }, { name: 'theme', type: 'line', data: art.theme, smooth: true, lineStyle: { color: '#10b981' }, showSymbol: false }] });
}

function renderCosHeatmap() {
  const el = document.getElementById('chart-cos-heatmap');
  if (!el) return;
  let ec = echarts.getInstanceByDom(el);
  if (!ec) ec = echarts.init(el);
  const d = buildCosHeatmapData(currentStep);
  ec.setOption({
    tooltip: { position: 'top', backgroundColor: '#111827', borderColor: '#2a3a5c', textStyle: { color: '#e2e8f0' } },
    grid: { left: 60, right: 20, top: 20, bottom: 60 },
    xAxis: { type: 'category', data: d.names, axisLabel: { color: '#94a3b8', rotate: 30 } },
    yAxis: { type: 'category', data: d.names, axisLabel: { color: '#94a3b8' } },
    visualMap: { min: -1, max: 1, calculable: true, inRange: { color: ['#f87171', '#fbbf24', '#34d399'] }, textStyle: { color: '#94a3b8' } },
    series: [{ type: 'heatmap', data: d.data, label: { show: true, color: '#fff', formatter: p => p.value[2].toFixed(3) }, emphasis: { itemStyle: { shadowBlur: 10, shadowColor: 'rgba(0,0,0,0.5)' } } }]
  });
}

function renderFHeatmap() {
  const el = document.getElementById('chart-f-heatmap');
  if (!el) return;
  let ec = echarts.getInstanceByDom(el);
  if (!ec) ec = echarts.init(el);
  const d = buildFHeatmapData(currentStep);
  ec.setOption({
    tooltip: { position: 'top', backgroundColor: '#111827', borderColor: '#2a3a5c', textStyle: { color: '#e2e8f0' } },
    grid: { left: 60, right: 20, top: 20, bottom: 60 },
    xAxis: { type: 'category', data: d.names, axisLabel: { color: '#94a3b8', rotate: 30 } },
    yAxis: { type: 'category', data: d.names, axisLabel: { color: '#94a3b8' } },
    visualMap: { min: -d.maxF, max: d.maxF, calculable: true, inRange: { color: ['#f87171', '#fbbf24', '#34d399'] }, textStyle: { color: '#94a3b8' } },
    series: [{ type: 'heatmap', data: d.data, label: { show: true, color: '#fff', formatter: p => p.value[2].toFixed(1) }, emphasis: { itemStyle: { shadowBlur: 10, shadowColor: 'rgba(0,0,0,0.5)' } } }]
  });
}

function updateTrajectoryCharts(step) {
  if (!appData || !appData.history || !appData.history.length || step >= appData.history.length) return;
  const ct = document.getElementById('chart-trajectory');
  if (ct) {
    const c = echarts.getInstanceByDom(ct);
    if (c) {
      const ids = getCharIds();
      const seriesUpdates = [];
      for (let i = 0; i < ids.length; i++) {
        const name = appData.characters[ids[i]].name;
        const vec = appData.history[step].snapshot[name];
        seriesUpdates.push({ name: name + ' 当前', data: [[vec[0], vec[1]]] });
      }
      c.setOption({ series: seriesUpdates });
    }
  }
  const cr = document.getElementById('chart-radar');
  if (cr) {
    const c = echarts.getInstanceByDom(cr);
    if (c) c.setOption({ series: [{ data: buildRadarData(step) }] });
  }
}

function updateNetworkCharts(step) {
  if (!appData || !appData.history || !appData.history.length || step >= appData.history.length) return;
  const cn = document.getElementById('chart-network');
  if (cn) {
    const c = echarts.getInstanceByDom(cn);
    if (c) { const net = buildNetworkData(step); c.setOption({ series: [{ type: 'graph', layout: 'circular', data: net.nodes, links: net.links }] }); }
  }
  const cfn = document.getElementById('chart-faction-net');
  if (cfn) {
    const c = echarts.getInstanceByDom(cfn);
    if (c) { const fnet = buildFactionNetworkData(step); c.setOption({ series: [{ type: 'graph', layout: 'circular', data: fnet.nodes, links: fnet.links }] }); }
  }
}

function updateFactionCharts(step) {
  if (!appData || !appData.history || !appData.history.length) return;
  const cfp = document.getElementById('chart-faction-pull');
  if (cfp) {
    const c = echarts.getInstanceByDom(cfp);
    if (c) c.setOption({ xAxis: { data: getCharNames() }, series: buildFactionPullData(step) }, true);
  }
  const cfr = document.getElementById('chart-faction-rise');
  if (cfr) {
    const c = echarts.getInstanceByDom(cfr);
    if (c) {
      const riseData = buildFactionRiseData(step);
      c.setOption({ xAxis: { data: appData.history.map(h => h.step) }, series: riseData }, true);
    }
  }
}

function updateEventsCharts(step) {
  if (!appData || !appData.history || !appData.history.length) return;
  const ct = document.getElementById('chart-timeline');
  if (ct) {
    const c = echarts.getInstanceByDom(ct);
    if (c) {
      c.setOption({
        xAxis: { markLine: { silent: true, data: [{ xAxis: step, lineStyle: { color: '#60a5fa', width: 2 }, label: { formatter: '步' + step, color: '#60a5fa', position: 'insideEndTop' } }] } }
      });
    }
  }
  const ca = document.getElementById('chart-art');
  if (ca) {
    const c = echarts.getInstanceByDom(ca);
    if (c) {
      const art = buildArtData(step);
      c.setOption({ series: [{ name: 'dramatic', data: art.dramatic }, { name: 'surprise', data: art.surprise }, { name: 'theme', data: art.theme }] });
    }
  }
}

function updatePhysicsCharts(step) {
  if (!appData || !appData.history || !appData.history.length) return;
  const cg = document.getElementById('chart-gauss'); const ca = document.getElementById('chart-art');
  if (ca) { const c = echarts.getInstanceByDom(ca); if (c) { const art = buildArtData(step); c.setOption({ xAxis: { markLine: { silent: true, data: [{ xAxis: step, lineStyle: { color: '#f59e0b', type: 'dashed' }, label: { formatter: 'Step ' + step, color: '#f59e0b' } }] } } }); } }
}

function updateDataCharts(step) {
  if (!appData || !appData.history || !appData.history.length || step >= appData.history.length) return;
  const ch = document.getElementById('chart-cos-heatmap');
  if (ch) {
    const c = echarts.getInstanceByDom(ch);
    if (c) {
      const d = buildCosHeatmapData(step);
      c.setOption({ xAxis: { data: d.names }, yAxis: { data: d.names }, series: [{ data: d.data }] });
    }
  }
  const fh = document.getElementById('chart-f-heatmap');
  if (fh) {
    const c = echarts.getInstanceByDom(fh);
    if (c) {
      const d = buildFHeatmapData(step);
      c.setOption({ xAxis: { data: d.names }, yAxis: { data: d.names }, series: [{ data: d.data }], visualMap: { min: -d.maxF, max: d.maxF } });
    }
  }
  const tbody = document.querySelector('#live-data-table tbody');
  if (tbody) {
    const names = getCharNames();
    const rec = appData.history[step];
    const rows = tbody.querySelectorAll('tr');
    names.forEach((name, i) => {
      if (rows[i]) {
        const vec = rec.snapshot[name];
        const eff = rec.eff_vectors[name] || [0,0,0,0];
        const alive = appData.characters[name].alive ? '存活' : '<span style="color:#ef4444">死亡</span>';
        rows[i].children[0].innerHTML = '<strong>' + name + '</strong>';
        rows[i].children[1].innerHTML = alive;
        for (let j = 0; j < 4; j++) rows[i].children[2 + j].textContent = vec[j].toFixed(3);
        for (let j = 0; j < 4; j++) rows[i].children[6 + j].textContent = eff[j].toFixed(3);
      }
    });
  }
}

function exportJSON() {
  if (!appData || !appData.history) return;
  const output = { meta_rules: appData.meta, characters: {}, gravity_factors: appData.factors.map(f => ({ name: f.name, mass: f.mass, field_type: f.field_type, field_params: f.field_params, affiliation_weights: f.affiliation_weights })), evolution_history: appData.history, anchor_events: appData.anchor_log, interference_analysis: appData.interference };
  for (const [name, char] of Object.entries(appData.characters)) output.characters[name] = char.snapshot();
  const blob = new Blob([JSON.stringify(output, null, 2)], { type: 'application/json' }); const url = URL.createObjectURL(blob); const a = document.createElement('a'); a.href = url; a.download = 'gravityworld_v32_report.json'; a.click(); URL.revokeObjectURL(url);
}
function exportCSV() {
  if (!appData || !appData.history) return;
  const lines = ['step,character,dim1,dim2,dim3,dim4,eff1,eff2,eff3,eff4'];
  for (const rec of appData.history) { for (const [name, vec] of Object.entries(rec.snapshot)) { const eff = rec.eff_vectors[name] || [0,0,0,0]; lines.push(`${rec.step},${name},${vec.join(',')},${eff.join(',')}`); } }
  const blob = new Blob(['\ufeff' + lines.join('\n')], { type: 'text/csv;charset=utf-8;' }); const url = URL.createObjectURL(blob); const a = document.createElement('a'); a.href = url; a.download = 'gravityworld_v32_evolution.csv'; a.click(); URL.revokeObjectURL(url);
}

document.getElementById('fileInput').addEventListener('change', function(e) {
  const file = e.target.files[0]; if (!file) return;
  const reader = new FileReader();
  reader.onload = function(ev) {
    try {
      const config = JSON.parse(ev.target.result);
      const { meta, factors, characters, anchors, art_weights } = loadV32Config(config);
      const faction_manager = new FactionManager(); faction_manager.init_from_factors(factors); faction_manager.assign_members(characters, meta);
      appData = { meta, factors, characters, anchors, art_weights, faction_manager, data: config, history: [], anchor_log: [] };
      document.getElementById('sidebarEmpty').style.display = 'none';
      document.getElementById('sidebarContent').style.display = 'block';
      document.getElementById('charCheckboxes').innerHTML = Object.keys(characters).map(k => `<div class="checkbox-row"><input type="checkbox" checked id="ch-${k}"><label for="ch-${k}">${characters[k].name}</label></div>`).join('');
      document.getElementById('factionCheckboxes').innerHTML = Object.keys(faction_manager.factions).map(k => `<div class="checkbox-row"><input type="checkbox" checked id="fa-${k}"><label for="fa-${k}">${k}</label></div>`).join('');
      const mc = document.getElementById('mainContent');
      mc.innerHTML = `
        <div class="stat-bar">
          <div class="stat-chip"><div class="stat-chip-value" id="stat-steps">0</div><div class="stat-chip-label">推演步数</div></div>
          <div class="stat-chip"><div class="stat-chip-value" id="stat-chars">${Object.keys(characters).length}</div><div class="stat-chip-label">角色数</div></div>
          <div class="stat-chip"><div class="stat-chip-value" id="stat-factions">${Object.keys(faction_manager.factions).length}</div><div class="stat-chip-label">势力数</div></div>
          <div class="stat-chip"><div class="stat-chip-value" id="stat-pairs">0</div><div class="stat-chip-label">关系对</div></div>
          <div class="stat-chip"><div class="stat-chip-value" id="stat-anchors">${anchors.length}</div><div class="stat-chip-label">锚点事件</div></div>
          <div class="stat-chip"><div class="stat-chip-value" id="stat-defections">0</div><div class="stat-chip-label">叛变事件</div></div>
        </div>
        <div class="main-tabs">
          <button class="main-tab active" data-tab="data" onclick="switchTab('data')">📋 原始数据</button>
          <button class="main-tab" data-tab="trajectory" onclick="switchTab('trajectory')">📈 轨迹演化</button>
          <button class="main-tab" data-tab="network" onclick="switchTab('network')">🕸️ 关系网络</button>
          <button class="main-tab" data-tab="faction" onclick="switchTab('faction')">🏛️ 势力分析</button>
          <button class="main-tab" data-tab="events" onclick="switchTab('events')">⚡ 事件时间线</button>
          <button class="main-tab" data-tab="physics" onclick="switchTab('physics')">🔬 物理引擎</button>
        </div>
        <div class="tab-panel active" data-tab="data" id="tab-data"></div>
        <div class="tab-panel" data-tab="trajectory" id="tab-trajectory"></div>
        <div class="tab-panel" data-tab="network" id="tab-network"></div>
        <div class="tab-panel" data-tab="faction" id="tab-faction"></div>
        <div class="tab-panel" data-tab="events" id="tab-events"></div>
        <div class="tab-panel" data-tab="physics" id="tab-physics"></div>
      `;
      currentTab = 'data'; renderCurrentTab();
    } catch (err) { alert('解析失败: ' + err.message); }
  };
  reader.readAsText(file);
});

document.addEventListener('change', function(e) {
  if (!appData) return;
  const tid = e.target.id;
  if (!tid) return;
  if (tid.startsWith('ch-') || tid.startsWith('fa-')) {
    const activePanel = document.querySelector('.tab-panel.active');
    if (!activePanel) return;
    activePanel.innerHTML = '';
    renderCurrentTab();
  }
});

window.addEventListener('resize', () => { document.querySelectorAll('.tab-panel').forEach(p => { p.querySelectorAll('[id^="chart-"]').forEach(div => { const c = echarts.getInstanceByDom(div); if (c) c.resize(); }); }); });
</script></body>
</html>
